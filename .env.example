# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Database (used by Spring Boot and docker-compose postgres)
DB_URL=jdbc:postgresql://localhost:5433/bank_cards
DB_USERNAME=
DB_PASSWORD=

# Security secrets — generate your own, never commit .env
JWT_SECRET=
AES_SECRET_KEY=
JWT_EXPIRATION_MS=3600000

# Bootstrap admin (created on first startup if no ADMIN exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

SPRING_PROFILES_ACTIVE=dev
